{
  "app_name": "EduFER Demo",
  "environment": "development",
  "host": "127.0.0.1",
  "port": 8000,
  "detection": {
    "model_path": "data/models/face_detection/yolov8n-face-lindevs.onnx",
    "download_url": "https://github.com/lindevs/yolov8-face/releases/latest/download/yolov8n-face-lindevs.onnx",
    "sha256": "8d0bfb0c3383c5bd7a78dd24ef79a21e2aa456619b6ab5e53867092d1c7dc414",
    "input_size": 640,
    "confidence_threshold": 0.6,
    "iou_threshold": 0.45
  },
  "classification": {
    "default_label": "bored",
    "default_confidence": 0.88
  },
  "web": {
    "static_dir": "src/edufer/web/static",
    "capture_interval_ms": 1200
  },
  "security": {
    "cors_allowed_origins": [
      "http://localhost:8000",
      "http://127.0.0.1:8000"
    ],
    "cors_allowed_methods": [
      "GET",
      "POST"
    ],
    "cors_allowed_headers": [
      "Accept",
      "Authorization",
      "Content-Type",
      "Origin"
    ],
    "cors_allow_credentials": false,
    "trusted_hosts": [
      "localhost",
      "127.0.0.1",
      "testserver"
    ],
    "max_request_bytes": 5000000,
    "enable_https_redirect": false,
    "content_security_policy": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'",
    "permissions_policy": "camera=(self), microphone=()"
  }
}
