        "import hashlib\n",
        "import math\n",
        "import os\n",
        "import shutil\n",
        "import urllib.request\n",
        "\n",
        "import cv2\n",
        "from mediapipe.python.solutions import face_mesh as mp_face_mesh\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import torch\n",
        "\n",
        "# --- Configuration for frame extraction and alignment ---\n",
        "drive_root = \"/content/drive/MyDrive/ML_edufer\"\n",
        "daisee_root = os.path.join(drive_root, \"DAiSEE\")\n",
        "base_video_dir = os.path.join(daisee_root, \"DataSet\")\n",
        "output_frames_base_dir = os.path.join(drive_root, \"DAiSEE_Faces_Binary_YOLOv8Face_Aligned\")\n",
        "labels_dir = os.path.join(daisee_root, \"Labels\")\n",
        "TARGET_LABEL_COLUMN = \"BinaryEngagement\"\n",
        "FRAMES_PER_VIDEO = 5\n",
        "FACE_PADDING_RATIO = 0.25\n",
        "YOLO_INPUT_SIZE = 640\n",
        "YOLO_CONFIDENCE_THRESHOLD = 0.6\n",
        "YOLO_IOU_THRESHOLD = 0.45\n",
        "YOLO_FACE_MODEL_URL = \"https://github.com/lindevs/yolov8-face/releases/latest/download/yolov8n-face-lindevs.onnx\"\n",
        "YOLO_FACE_MODEL_SHA256 = \"8d0bfb0c3383c5bd7a78dd24ef79a21e2aa456619b6ab5e53867092d1c7dc414\"\n",
        "YOLO_FACE_MODEL_PATH = os.path.join(drive_root, \"models\", \"yolov8n-face-lindevs.onnx\")\n",
        "\n",
        "LEFT_EYE_INDICES = [33, 133, 159, 145, 158, 153]\n",
        "RIGHT_EYE_INDICES = [362, 263, 386, 374, 385, 380]\n",
        "\n",
        "\n",
        "def sha256sum(file_path):\n",
        "    digest = hashlib.sha256()\n",
        "    with open(file_path, \"rb\") as handle:\n",
        "        for chunk in iter(lambda: handle.read(1024 * 1024), b\"\"):\n",
        "            digest.update(chunk)\n",
        "    return digest.hexdigest()\n",
        "\n",
        "\n",
        "def ensure_yolov8_face_model(model_path, url, expected_sha256):\n",
        "    os.makedirs(os.path.dirname(model_path), exist_ok=True)\n",
        "    if not os.path.exists(model_path):\n",
        "        print(f\"Downloading YOLOv8-Face model from {url}...\")\n",
        "        urllib.request.urlretrieve(url, model_path)\n",
        "        print(f\"Model downloaded to: {model_path}\")\n",
        "    else:\n",
        "        print(f\"YOLOv8-Face model already exists at: {model_path}\")\n",
        "\n",
        "    digest = sha256sum(model_path)\n",
        "    print(f\"YOLOv8-Face SHA-256: {digest}\")\n",
        "    if expected_sha256 and digest != expected_sha256:\n",
        "        raise ValueError(\n",
        "            \"Checksum mismatch for YOLOv8-Face ONNX model. \"\n",
        "            \"Delete the file and rerun the cell to download it again.\"\n",
        "        )\n",
        "\n",
        "\n",
        "def select_runtime_device():\n",
        "    if torch.cuda.is_available():\n",
        "        return torch.device(\"cuda\")\n",
        "    if getattr(torch.backends, \"mps\", None) and torch.backends.mps.is_available():\n",
        "        return torch.device(\"mps\")\n",
        "    return torch.device(\"cpu\")\n",
        "\n",
        "\n",
        "class YOLOv8FaceDetector:\n",
        "    def __init__(\n",
        "        self,\n",
        "        model_path,\n",
        "        input_size=640,\n",
        "        confidence_threshold=0.6,\n",
        "        iou_threshold=0.45,\n",
        "        prefer_cuda=True,\n",
        "    ):\n",
        "        self.model_path = model_path\n",
        "        self.input_size = input_size\n",
        "        self.confidence_threshold = confidence_threshold\n",
        "        self.iou_threshold = iou_threshold\n",
        "        self.net = cv2.dnn.readNetFromONNX(model_path)\n",
        "        self.backend_name = \"OpenCV CPU\"\n",
        "\n",
        "        if prefer_cuda and cv2.cuda.getCudaEnabledDeviceCount() > 0:\n",
        "            self.net.setPreferableBackend(cv2.dnn.DNN_BACKEND_CUDA)\n",
        "            self.net.setPreferableTarget(cv2.dnn.DNN_TARGET_CUDA)\n",
        "            self.backend_name = \"OpenCV DNN CUDA\"\n",
        "        else:\n",
        "            self.net.setPreferableBackend(cv2.dnn.DNN_BACKEND_OPENCV)\n",
        "            self.net.setPreferableTarget(cv2.dnn.DNN_TARGET_CPU)\n",
        "\n",
        "    def detect_largest_face(self, frame_bgr):\n",
        "        height, width = frame_bgr.shape[:2]\n",
        "        length = max(height, width)\n",
        "        scale = length / self.input_size\n",
        "\n",
        "        canvas = np.zeros((length, length, 3), dtype=np.uint8)\n",
        "        canvas[0:height, 0:width] = frame_bgr\n",
        "\n",
        "        blob = cv2.dnn.blobFromImage(\n",
        "            canvas,\n",
        "            scalefactor=1 / 255,\n",
        "            size=(self.input_size, self.input_size),\n",
        "            swapRB=True,\n",
        "        )\n",
        "        self.net.setInput(blob)\n",
        "        outputs = self.net.forward()\n",
        "        predictions = cv2.transpose(outputs[0])\n",
        "\n",
        "        boxes = []\n",
        "        scores = []\n",
        "        for row in predictions:\n",
        "            score = float(np.max(row[4:])) if row.shape[0] > 5 else float(row[4])\n",
        "            if score < self.confidence_threshold:\n",
        "                continue\n",
        "\n",
        "            x = float((row[0] - (0.5 * row[2])) * scale)\n",
        "            y = float((row[1] - (0.5 * row[3])) * scale)\n",
        "            w = float(row[2] * scale)\n",
        "            h = float(row[3] * scale)\n",
        "            boxes.append([x, y, w, h])\n",
        "            scores.append(score)\n",
        "\n",
        "        if not boxes:\n",
        "            return None\n",
        "\n",
        "        indices = cv2.dnn.NMSBoxes(\n",
        "            boxes,\n",
        "            scores,\n",
        "            self.confidence_threshold,\n",
        "            self.iou_threshold,\n",
        "        )\n",
        "        normalized_indices = normalize_indices(indices)\n",
        "        if not normalized_indices:\n",
        "            return None\n",
        "\n",
        "        best_index = max(normalized_indices, key=lambda idx: scores[idx])\n",
        "        x, y, w, h = boxes[best_index]\n",
        "        x1 = max(0, int(round(x)))\n",
        "        y1 = max(0, int(round(y)))\n",
        "        x2 = min(width, int(round(x + w)))\n",
        "        y2 = min(height, int(round(y + h)))\n",
        "\n",
        "        if x2 <= x1 or y2 <= y1:\n",
        "            return None\n",
        "        return np.array([x1, y1, x2, y2], dtype=np.float32)\n",
        "\n",
        "\n",
        "def normalize_indices(indices):\n",
        "    if indices is None or len(indices) == 0:\n",
        "        return []\n",
        "\n",
        "    normalized = []\n",
        "    for index in indices:\n",
        "        if isinstance(index, (list, tuple, np.ndarray)):\n",
        "            normalized.append(int(index[0]))\n",
        "        else:\n",
        "            normalized.append(int(index))\n",
        "    return normalized\n",
        "\n",
        "\n",
        "def get_binary_engagement_label(row):\n",
        "    engagement = row.get(\"Engagement\", 0)\n",
        "    boredom = row.get(\"Boredom\", 0)\n",
        "    confusion = row.get(\"Confusion\", 0)\n",
        "    frustration = row.get(\"Frustration\", 0)\n",
        "\n",
        "    if engagement <= 1 or boredom >= 2 or confusion >= 2 or frustration >= 2:\n",
        "        return \"0\"\n",
        "    if engagement >= 2 and boredom <= 1 and confusion <= 1 and frustration <= 1:\n",
        "        return \"1\"\n",
        "    return \"0\"\n",
        "\n",
        "\n",
        "def clip_box_to_frame(box_xyxy, frame_shape, padding_ratio=0.25):\n",
        "    x1, y1, x2, y2 = box_xyxy\n",
        "    h, w = frame_shape[:2]\n",
        "    box_w = x2 - x1\n",
        "    box_h = y2 - y1\n",
        "    padding = int(max(box_w, box_h) * padding_ratio)\n",
        "\n",
        "    x1 = max(0, int(math.floor(x1 - padding)))\n",
        "    y1 = max(0, int(math.floor(y1 - padding)))\n",
        "    x2 = min(w, int(math.ceil(x2 + padding)))\n",
        "    y2 = min(h, int(math.ceil(y2 + padding)))\n",
        "    return x1, y1, x2, y2\n",
        "\n",
        "\n",
        "def compute_eye_center(landmarks, indices, crop_w, crop_h):\n",
        "    points = np.array(\n",
        "        [(landmarks[idx].x * crop_w, landmarks[idx].y * crop_h) for idx in indices],\n",
        "        dtype=np.float32,\n",
        "    )\n",
        "    return points.mean(axis=0)\n",
        "\n",
        "\n",
        "def align_face_crop(face_crop_bgr, face_mesh):\n",
        "    if face_crop_bgr.size == 0:\n",
        "        return None, None\n",
        "\n",
        "    rgb_crop = cv2.cvtColor(face_crop_bgr, cv2.COLOR_BGR2RGB)\n",
        "    mesh_result = face_mesh.process(rgb_crop)\n",
        "    if not mesh_result.multi_face_landmarks:\n",
        "        return None, None\n",
        "\n",
        "    landmarks = mesh_result.multi_face_landmarks[0].landmark\n",
        "    crop_h, crop_w = face_crop_bgr.shape[:2]\n",
        "    left_eye = compute_eye_center(landmarks, LEFT_EYE_INDICES, crop_w, crop_h)\n",
        "    right_eye = compute_eye_center(landmarks, RIGHT_EYE_INDICES, crop_w, crop_h)\n",
        "\n",
        "    delta = right_eye - left_eye\n",
        "    if np.linalg.norm(delta) < 1e-6:\n",
        "        return None, None\n",
        "\n",
        "    angle = math.degrees(math.atan2(delta[1], delta[0]))\n",
        "    eye_center = tuple(((left_eye + right_eye) / 2.0).tolist())\n",
        "    rotation_matrix = cv2.getRotationMatrix2D(eye_center, angle, 1.0)\n",
        "    aligned_face = cv2.warpAffine(\n",
        "        face_crop_bgr,\n",
        "        rotation_matrix,\n",
        "        (crop_w, crop_h),\n",
        "        flags=cv2.INTER_CUBIC,\n",
        "        borderMode=cv2.BORDER_REPLICATE,\n",
        "    )\n",
        "\n",
        "    alignment_info = {\n",
        "        \"left_eye\": left_eye.tolist(),\n",
        "        \"right_eye\": right_eye.tolist(),\n",
        "        \"rotation_angle_deg\": float(angle),\n",
        "    }\n",
        "    return aligned_face, alignment_info\n",
        "\n",
        "\n",
        "def extract_and_organize_faces(\n",
        "    label_df,\n",
        "    video_base_path,\n",
        "    output_base_path,\n",
        "    set_name,\n",
        "    label_column,\n",
        "    frames_per_video,\n",
        "    detector,\n",
        "    face_mesh,\n",
        "):\n",
        "    print(f\"Processing {set_name} set...\")\n",
        "    total_videos = len(label_df)\n",
        "    processed_videos = 0\n",
        "    skipped_videos = 0\n",
        "    no_face_detected_frames = 0\n",
        "    fallback_unaligned_faces = 0\n",
        "    aligned_faces = 0\n",
        "\n",
        "    set_output_dir = os.path.join(output_base_path, set_name)\n",
        "    if os.path.exists(set_output_dir):\n",
        "        shutil.rmtree(set_output_dir)\n",
        "    os.makedirs(set_output_dir)\n",
        "\n",
        "    os.makedirs(os.path.join(set_output_dir, \"0\"), exist_ok=True)\n",
        "    os.makedirs(os.path.join(set_output_dir, \"1\"), exist_ok=True)\n",
        "\n",
        "    for _, row in label_df.iterrows():\n",
        "        full_clip_id_with_ext = str(row[\"ClipID\"])\n",
        "        label_value = str(row[label_column])\n",
        "        clip_folder_name = os.path.splitext(full_clip_id_with_ext)[0]\n",
        "\n",
        "        if len(clip_folder_name) < 6:\n",
        "            print(\n",
        "                f\"Warning: ClipID '{full_clip_id_with_ext}' is too short to extract SubjectID. Skipping video.\"\n",
        "            )\n",
        "            skipped_videos += 1\n",
        "            continue\n",
        "\n",
        "        subject_id = clip_folder_name[:6]\n",
        "        current_video_path = os.path.join(\n",
        "            video_base_path,\n",
        "            set_name,\n",
        "            subject_id,\n",
        "            clip_folder_name,\n",
        "            full_clip_id_with_ext,\n",
        "        )\n",
        "\n",
        "        if not os.path.exists(current_video_path):\n",
        "            print(\n",
        "                f\"Video file not found for ClipID: {full_clip_id_with_ext} at {current_video_path}. Skipping.\"\n",
        "            )\n",
        "            skipped_videos += 1\n",
        "            continue\n",
        "\n",
        "        output_label_dir = os.path.join(set_output_dir, label_value)\n",
        "        cap = cv2.VideoCapture(current_video_path)\n",
        "        if not cap.isOpened():\n",
        "            print(f\"Error: Could not open video {current_video_path}. Skipping.\")\n",
        "            skipped_videos += 1\n",
        "            cap.release()\n",
        "            continue\n",
        "\n",
        "        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
        "        if frame_count == 0:\n",
        "            print(f\"Video {current_video_path} has 0 frames. Skipping.\")\n",
        "            skipped_videos += 1\n",
        "            cap.release()\n",
        "            continue\n",
        "\n",
        "        frame_indices = [\n",
        "            int(i * frame_count / (frames_per_video + 1))\n",
        "            for i in range(1, frames_per_video + 1)\n",
        "        ]\n",
        "\n",
        "        for idx in frame_indices:\n",
        "            cap.set(cv2.CAP_PROP_POS_FRAMES, idx)\n",
        "            ret, frame = cap.read()\n",
        "            if not ret:\n",
        "                continue\n",
        "\n",
        "            detected_box = detector.detect_largest_face(frame)\n",
        "            if detected_box is None:\n",
        "                no_face_detected_frames += 1\n",
        "                continue\n",
        "\n",
        "            x1, y1, x2, y2 = clip_box_to_frame(\n",
        "                detected_box, frame.shape, FACE_PADDING_RATIO\n",
        "            )\n",
        "            face_crop = frame[y1:y2, x1:x2]\n",
        "            if face_crop.size == 0:\n",
        "                no_face_detected_frames += 1\n",
        "                continue\n",
        "\n",
        "            aligned_face, alignment_info = align_face_crop(face_crop, face_mesh)\n",
        "            if aligned_face is None:\n",
        "                aligned_face = face_crop\n",
        "                fallback_unaligned_faces += 1\n",
        "            else:\n",
        "                aligned_faces += 1\n",
        "\n",
        "            face_filename = os.path.join(\n",
        "                output_label_dir, f\"{clip_folder_name}_face_{idx:05d}.jpg\"\n",
        "            )\n",
        "            cv2.imwrite(face_filename, aligned_face)\n",
        "\n",
        "        cap.release()\n",
        "        processed_videos += 1\n",
        "        if processed_videos % 100 == 0:\n",
        "            print(\n",
        "                f\"Processed {processed_videos}/{total_videos} videos in {set_name} set.\"\n",
        "            )\n",
        "\n",
        "    print(\n",
        "        f\"Finished processing {set_name} set. Processed {processed_videos} videos, skipped {skipped_videos}, \"\n",
        "        f\"frames with no faces: {no_face_detected_frames}, aligned faces: {aligned_faces}, \"\n",
        "        f\"fallback unaligned faces: {fallback_unaligned_faces}.\"\n",
        "    )\n",
        "\n",
        "\n",
        "runtime_device = select_runtime_device()\n",
        "if runtime_device.type == \"cuda\":\n",
        "    torch.backends.cudnn.benchmark = True\n",
        "\n",
        "ensure_yolov8_face_model(\n",
        "    YOLO_FACE_MODEL_PATH,\n",
        "    YOLO_FACE_MODEL_URL,\n",
        "    YOLO_FACE_MODEL_SHA256,\n",
        ")\n",
        "yolo_face_detector = YOLOv8FaceDetector(\n",
        "    YOLO_FACE_MODEL_PATH,\n",
        "    input_size=YOLO_INPUT_SIZE,\n",
        "    confidence_threshold=YOLO_CONFIDENCE_THRESHOLD,\n",
        "    iou_threshold=YOLO_IOU_THRESHOLD,\n",
        "    prefer_cuda=(runtime_device.type == \"cuda\"),\n",
        ")\n",
        "\n",
        "print(f\"Using runtime device for PyTorch: {runtime_device}\")\n",
        "print(f\"Using face detector backend: {yolo_face_detector.backend_name}\")\n",
        "print(f\"Loaded YOLOv8-Face ONNX model from: {YOLO_FACE_MODEL_PATH}\")\n",
        "\n",
        "face_mesh = mp_face_mesh.FaceMesh(\n",
        "    static_image_mode=True,\n",
        "    max_num_faces=1,\n",
        "    refine_landmarks=True,\n",
        "    min_detection_confidence=0.5,\n",
        "    min_tracking_confidence=0.5,\n",
        ")\n",
        "print(\"MediaPipe Face Mesh initialized for face alignment.\")\n",
        "\n",
        "os.makedirs(output_frames_base_dir, exist_ok=True)\n",
        "\n",
        "print(\"Loading labels...\")\n",
        "train_labels_df = pd.read_csv(os.path.join(labels_dir, \"TrainLabels.csv\"))\n",
        "val_labels_df = pd.read_csv(os.path.join(labels_dir, \"ValidationLabels.csv\"))\n",
        "test_labels_df = pd.read_csv(os.path.join(labels_dir, \"TestLabels.csv\"))\n",
        "\n",
        "for df_name, df in [\n",
        "    (\"Train\", train_labels_df),\n",
        "    (\"Validation\", val_labels_df),\n",
        "    (\"Test\", test_labels_df),\n",
        "]:\n",
        "    df.columns = df.columns.str.strip()\n",
        "    print(f\"{df_name} labels columns after strip: {df.columns.tolist()}\")\n",
        "\n",
        "print(\"Applying binary engagement classification logic...\")\n",
        "train_labels_df[TARGET_LABEL_COLUMN] = train_labels_df.apply(\n",
        "    get_binary_engagement_label, axis=1\n",
        ")\n",
        "val_labels_df[TARGET_LABEL_COLUMN] = val_labels_df.apply(\n",
        "    get_binary_engagement_label, axis=1\n",
        ")\n",
        "test_labels_df[TARGET_LABEL_COLUMN] = test_labels_df.apply(\n",
        "    get_binary_engagement_label, axis=1\n",
        ")\n",
        "\n",
        "extract_and_organize_faces(\n",
        "    train_labels_df,\n",
        "    base_video_dir,\n",
        "    output_frames_base_dir,\n",
        "    \"Train\",\n",
        "    TARGET_LABEL_COLUMN,\n",
        "    FRAMES_PER_VIDEO,\n",
        "    yolo_face_detector,\n",
        "    face_mesh,\n",
        ")\n",
        "extract_and_organize_faces(\n",
        "    val_labels_df,\n",
        "    base_video_dir,\n",
        "    output_frames_base_dir,\n",
        "    \"Validation\",\n",
        "    TARGET_LABEL_COLUMN,\n",
        "    FRAMES_PER_VIDEO,\n",
        "    yolo_face_detector,\n",
        "    face_mesh,\n",
        ")\n",
        "extract_and_organize_faces(\n",
        "    test_labels_df,\n",
        "    base_video_dir,\n",
        "    output_frames_base_dir,\n",
        "    \"Test\",\n",
        "    TARGET_LABEL_COLUMN,\n",
        "    FRAMES_PER_VIDEO,\n",
        "    yolo_face_detector,\n",
        "    face_mesh,\n",
        ")\n",
        "\n",
        "face_mesh.close()\n",
        "print(f\"All YOLOv8-Face-aligned faces extracted and organized to: {output_frames_base_dir}\")\n",
        "print(\n",
        "    \"Note: YOLOv8-Face ONNX can use OpenCV DNN CUDA when available; MediaPipe Face Mesh alignment is typically CPU-bound.\"\n",
        ")\n"
      ]
    },
