        "import os\n",
        "import shutil\n",
        "\n",
        "source_binary_faces_dir = \"/content/drive/MyDrive/ML_edufer/DAiSEE_Faces_Binary_YOLOv8Face_Aligned\"\n",
        "target_drive_dir = \"/content/drive/MyDrive/ML_edufer/DAiSEE_Processed_Faces_Binary_YOLOv8Face_Aligned\"\n",
        "\n",
        "print(f\"Preparing aligned binary faces from {source_binary_faces_dir} to {target_drive_dir}...\")\n",
        "\n",
        "if os.path.exists(target_drive_dir):\n",
        "    print(f\"Removing existing directory in Drive: {target_drive_dir}\")\n",
        "    shutil.rmtree(target_drive_dir)\n",
        "\n",
        "if source_binary_faces_dir == target_drive_dir:\n",
